{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"var r=process.env.CLAUDE_PLUGIN_ROOT;if(r){var p=require('path');require(p.join(r,'hooks','set-env-vars.js'))}\"",
            "bash": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/set-env-vars.js\"",
            "powershell": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/set-env-vars.js\""
          }
        ]
      }
    ]
  }
}